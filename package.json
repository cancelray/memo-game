{
	"name": "memo-game-ts",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"homepage": "https://cancelray.github.io/memo-game/",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"server": "json-server --watch db.json5 --port 3001",
		"lint": "eslint .",
		"preview": "vite preview",
		"copy404": "cpy dist/index.html dist --rename=404.html --flat",
		"predeploy": "run-s build copy404",
		"deploy": "gh-pages -d dist"
	},
	"dependencies": {
		"@reduxjs/toolkit": "^2.12.0",
		"json-server": "^1.0.0-beta.15",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-redux": "^9.3.0",
		"react-router-dom": "^7.18.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.13.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"cpy-cli": "^7.0.0",
		"eslint": "^10.6.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"gh-pages": "^6.3.0",
		"globals": "^17.7.0",
		"npm-run-all": "^4.1.5",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.1"
	}
}
